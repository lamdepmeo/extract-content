generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum JobStatus {
  QUEUED
  RUNNING
  DONE
  FAILED
}

enum UrlType {
  POST
  CATEGORY
  OTHER
}

model Job {
  id          String      @id @default(cuid())
  sitemapUrl  String
  status      JobStatus   @default(QUEUED)
  totalUrls   Int         @default(0)
  processed   Int         @default(0)
  failed      Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  urlRecords  UrlRecord[]
}

model UrlRecord {
  id             String    @id @default(cuid())
  jobId           String
  job             Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  url             String
  sitemapUrl      String
  type            UrlType   @default(OTHER)
  lastmod         DateTime?
  imageCount      Int       @default(0)
  fetchStatusCode Int?
  fetchError      String?
  extractedText   String?
  keyword         String?
  topicSummary    String?
  processedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([jobId, url])
  @@index([jobId, type])
}
